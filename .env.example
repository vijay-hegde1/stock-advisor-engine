# Stock Advisor engine — environment variables
# Copy to .env for local dev (.env is gitignored). On Render, set these in the
# service's Environment settings instead.

# Anthropic API key (used by the advisor to call Claude).
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret the Yuktera portal must send in the X-Engine-Key header.
# Generate a long random string; set the SAME value in the portal's Vercel env.
ENGINE_SHARED_SECRET=generate-a-long-random-string

# Optional: which market is the default (IN_NSE or US).
DEFAULT_MARKET=IN_NSE
